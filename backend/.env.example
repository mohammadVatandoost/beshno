# ---------------------------------------------------------------------------
# Beshno backend configuration. Copy to `.env` and fill in what you need.
# With no keys set, the app runs fully on mock providers (search, LLM, TTS).
# ---------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
# PostgreSQL (default). For a zero-dependency local run use SQLite instead:
#   DATABASE_URL=sqlite:///./beshno.db
DATABASE_URL=postgresql+psycopg://beshno:beshno@localhost:5433/beshno

# --- LLM: Claude (Anthropic) ------------------------------------------------
# Leave ANTHROPIC_API_KEY empty to use the mock LLM.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# auto | claude | mock   (auto -> claude when a key is present, else mock)
LLM_PROVIDER=auto

# --- Search / retrieval: Tavily ---------------------------------------------
# auto | tavily | mock   (auto -> tavily when a key is present, else mock)
SEARCH_PROVIDER=auto
TAVILY_API_KEY=
SEARCH_MAX_RESULTS=10

# --- Text to speech: Google Cloud TTS ---------------------------------------
# auto | google | mock   (auto -> google when a key/credentials are present, else mock)
TTS_PROVIDER=auto
# Option A: a Google API key with the Text-to-Speech API enabled.
GOOGLE_API_KEY=
# Option B: path to a Google service-account JSON (Application Default Credentials).
GOOGLE_APPLICATION_CREDENTIALS=

# --- Pipeline ---------------------------------------------------------------
# Evaluator-driven revision cycles before flagging "needs_review".
MAX_REVISIONS=2
# Step budget for an agent's tool-use loop (e.g. Agent 1's MCP topic retrieval):
# max LLM turns before a final answer is forced. Use >= 2 for at least one tool call.
AGENT_MAX_STEPS=3
# Background worker threads that run generation off the request path.
# 0 (or less) runs generation synchronously/inline.
PIPELINE_WORKERS=4

# --- Storage ----------------------------------------------------------------
STORAGE_DIR=./storage

# --- CORS -------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
